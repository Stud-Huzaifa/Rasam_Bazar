NODE_ENV=production
PORT=10000
FRONTEND_URL=https://your-vercel-app.vercel.app
NEXT_PUBLIC_API_URL=https://your-render-api.onrender.com/api
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
JWT_ACCESS_SECRET=replace-with-strong-production-access-secret
JWT_REFRESH_SECRET=replace-with-strong-production-refresh-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ENABLE_SWAGGER=false
COOKIE_SECURE=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_PRIVATE_FOLDER=private
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRIVATE_BUCKET=
RESEND_API_KEY=
EMAIL_FROM=RasmBazaar <no-reply@your-domain.example>
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
